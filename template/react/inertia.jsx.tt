import { createInertiaApp } from '@inertiajs/react'

createInertiaApp({
  strictMode: true,
  pages: '../pages',
  defaults: {
    form: {
      forceIndicesArrayFormatInFormData: false,
      withAllErrors: true,
    },
    visitOptions: () => ({
      queryStringArrayFormat: 'brackets',
    }),
  },
})
